# .env.local — copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Single-user auth
FINLOG_USERNAME=your_username_here
FINLOG_PASSWORD=your_secure_password_here
SESSION_SECRET=generate_32_random_chars_here_openssl_rand_base64_32

# Supabase — NEXT_PUBLIC_ only for URL and anon key (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Service role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL (used for logout redirect in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
